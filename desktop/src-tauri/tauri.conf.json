{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexuSSH",
  "version": "1.0.21",
  "identifier": "org.hipogas.nexussh",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NexuSSH",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/xray"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5NkFEMzZFNzI2RkY5RTYKUldUbStXOXlidE5xZWQ0NUV3NnpvTi8zMjYrdEp1TjUwekJhWHNBYXJrL3dXZXlrR0k2b2ZIUDUK",
      "endpoints": [
        "https://github.com/hipocrisle/nexussh/releases/latest/download/latest.json"
      ]
    }
  }
}
